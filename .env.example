# Environment Configuration
# Copy this file to .env.local and configure per-project

# ===========================================
# ECC (Everything Claude Code) — Opt-in
# ===========================================
# Set to true to enable ECC functionality
ECC_ENABLED=false

# Hook profile: "standard" (default) or "strict" (production only)
ECC_HOOK_PROFILE=standard

# Comma-separated list of hooks to disable (PreToolUse, PostToolUse, session.created, etc.)
ECC_DISABLED_HOOKS=

# ===========================================
# OmO (Oh My OpenAgent) — Opt-in Features
# ===========================================
# Preserve todo state across compaction
OMO_TODO_CONTINUATION=false

# Compact at 80% context instead of overflow
OMO_PREEMPTIVE_COMPACTION=false

# Inject per-directory AGENTS.md files
OMO_DIR_INJECTOR=false

# Validate extended thinking blocks
OMO_THINKING_VALIDATOR=false

# ===========================================
# Notes
# ===========================================
# - Hashline edit is ALWAYS ON (no env var needed)
# - Sisyphus, ralph_loop, ulw_loop are DISABLED globally
# - See .opencode/oh-my-openagent.jsonc for OmO config
